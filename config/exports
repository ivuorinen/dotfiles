# theme_mode — shared bash/zsh read API (uses `local`, not strict POSIX).
# Behaviour matches local/bin/theme-mode but without forking.
theme_mode()
{
  local state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles-theme"
  local state_file="$state_dir/mode"
  if [ -r "$state_file" ]; then
    local m
    read -r m < "$state_file"
    if [ "$m" = "dark" ] || [ "$m" = "light" ]; then
      printf '%s\n' "$m"
      return 0
    fi
  fi
  # No state file. In an interactive shell we'll have already bootstrapped
  # below via apply, so the file should exist. If it doesn't, default safely.
  printf 'dark\n'
}

# theme-reapply — re-fire all theme handlers for the current mode (or
# $1), bypassing apply's idempotency guard. Refreshes LS_COLORS in the
# current shell from the dircolors handler's cache. Use after editing a
# palette to see the result without restarting the shell.
theme-reapply()
{
  local mode="${1:-$(theme_mode)}"
  case "$mode" in
    dark | light) ;;
    *)
      echo "theme-reapply: mode must be 'dark' or 'light' (got '$mode')" >&2
      return 2
      ;;
  esac
  local dotfiles="${DOTFILES:-$HOME/.dotfiles}"
  local handlers_dir="$dotfiles/config/theme/handlers.d"
  if [ ! -d "$handlers_dir" ]; then
    echo "theme-reapply: missing $handlers_dir" >&2
    return 1
  fi
  local rc=0 h
  for h in "$handlers_dir"/*; do
    if [ -x "$h" ]; then
      "$h" "$mode" || rc=1
    fi
  done
  local cache="${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles-theme/ls-colors"
  if [ -r "$cache" ]; then
    # shellcheck source=/dev/null
    . "$cache"
  fi
  local bat_theme_file="${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles-theme/bat-theme"
  [ -r "$bat_theme_file" ] && BAT_THEME="$(cat "$bat_theme_file")" && export BAT_THEME
  echo "theme-reapply: applied $mode"
  return $rc
}

# Theme orchestrator: bootstrap state + spawn watcher.
# Skip the watcher fork in SSH sessions — the remote OS is the wrong
# oracle; per-session OSC 11 via `apply $(theme-mode)` is the right
# fallback. Skip in non-interactive shells too: `bash -c '...'` and
# `bash -ic '...'` subshells don't need to fork a daemon and pay the
# bootstrap cost on every invocation.
case $- in
  *i*) _theme_interactive=1 ;;
  *) _theme_interactive=0 ;;
esac
if [ "$_theme_interactive" = 1 ] \
  && [ -x "${DOTFILES:-$HOME/.dotfiles}/config/theme/apply" ]; then
  if [ -z "${SSH_TTY:-}${SSH_CONNECTION:-}" ]; then
    watcher="${DOTFILES:-$HOME/.dotfiles}/config/theme/watcher"
    if [ -x "$watcher" ]; then
      "$watcher" > /dev/null 2>&1 &
      disown 2> /dev/null || true
    fi
  fi
  m="$("${DOTFILES:-$HOME/.dotfiles}/local/bin/theme-mode")"
  "${DOTFILES:-$HOME/.dotfiles}/config/theme/apply" "$m" > /dev/null 2>&1 || true
  unset m watcher
fi
unset _theme_interactive

