#!/usr/bin/env bash
# handlers.d/gh-dash — gh-dash reads a single config.yml that mixes user
# sections (PR/issue queries) with the inline `theme:` block, so we can't
# symlink-swap. Concat base.yml + the chosen theme palette into the theme
# state dir and let shells point gh-dash at it via GH_DASH_CONFIG
# (config/exports, config/fish/exports.fish). Writing outside ~/.config
# keeps config/gh-dash a plain dotbot symlink with no install.conf exclude.
set -uo pipefail

# shellcheck disable=SC1091
source "$(dirname -- "$0")/../_lib.sh"

mode="${1:-}"
[[ "$mode" = "dark" || "$mode" = "light" ]] || exit 2

dotfiles="${DOTFILES:-$HOME/.dotfiles}"
base="$dotfiles/config/gh-dash/base.yml"
theme="$dotfiles/config/theme/palettes.d/gh-dash.${mode}.theme.yml"
dst="${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles-theme/gh-dash-config.yml"

for f in "$base" "$theme"; do
  [[ -r "$f" ]] || {
    echo "gh-dash handler: missing $f" >&2
    exit 1
  }
done

content="$(
  cat -- "$base"
  printf '\n'
  cat -- "$theme"
)"
_atomic_write "$dst" "$content"
