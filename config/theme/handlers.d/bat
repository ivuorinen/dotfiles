#!/usr/bin/env bash
# handlers.d/bat — symlink ~/.config/bat/config to the matching palette
# and ensure the custom themes are registered with `bat cache --build`.
# Refuses to clobber a regular file at the destination (N-021 guard).
set -uo pipefail

# shellcheck disable=SC1091
source "$(dirname -- "$0")/../_lib.sh"

mode="${1:-}"
[[ "$mode" = "dark" || "$mode" = "light" ]] || exit 2

src="${DOTFILES:-$HOME/.dotfiles}/config/theme/palettes.d/bat.${mode}.config"
dst="$HOME/.config/bat/config"
[[ -r "$src" ]] || {
  echo "bat handler: missing palette $src" >&2
  exit 1
}

mkdir -p -- "$(dirname -- "$dst")"
_idempotent_ln_sf "$src" "$dst"

# Custom themes (Catppuccin *.tmTheme) live under ~/.config/bat/themes/
# and are only picked up after `bat cache --build`. Run lazily when the
# cache is missing so we don't re-syntect on every flip. A bat-less host
# (or a transient build error) must not poison the orchestrator's
# parallel-handler aggregation, so failures are silenced.
if command -v bat > /dev/null 2>&1; then
  cache_dir="$(bat --cache-dir 2> /dev/null || true)"
  if [[ -n "$cache_dir" && ! -f "$cache_dir/themes.bin" ]]; then
    bat cache --build > /dev/null 2>&1 || true
  fi
fi
