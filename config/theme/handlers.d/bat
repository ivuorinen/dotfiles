#!/usr/bin/env bash
# handlers.d/bat — publish the active Catppuccin theme NAME to the theme
# state dir; shells export it as BAT_THEME (config/exports and
# config/fish/exports.fish). bat reads BAT_THEME at exec time, so theming
# never writes into ~/.config/bat — config/bat is a plain dotbot symlink
# with no install.conf exclude. Also (re)builds the syntect cache once so
# the vendored Catppuccin *.tmTheme files under ~/.config/bat/themes/
# resolve by name.
set -uo pipefail

# shellcheck disable=SC1091
source "$(dirname -- "$0")/../_lib.sh"

mode="${1:-}"
case "$mode" in
  dark) theme="Catppuccin Mocha" ;;
  light) theme="Catppuccin Latte" ;;
  *) exit 2 ;;
esac

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles-theme"
_atomic_write "$state_dir/bat-theme" "$theme"

# Custom themes are only picked up after `bat cache --build`. Build lazily
# when the cache is missing so we don't re-syntect on every flip. A bat-less
# host (or a transient build error) must not poison the orchestrator's
# parallel-handler aggregation, so failures are silenced.
if command -v bat > /dev/null 2>&1; then
  cache_dir="$(bat --cache-dir 2> /dev/null || true)"
  if [[ -n "$cache_dir" && ! -f "$cache_dir/themes.bin" ]]; then
    bat cache --build > /dev/null 2>&1 || true
  fi
fi
