      return 1
  fi

  local spec_file="${TMPDIR:-/tmp}/usage__usage_spec_x_path_prepend.spec"
  cat >| "$spec_file" <<'__USAGE_EOF__'
name x-path-prepend
bin x-path-prepend
about "Prepend directories to PATH"
arg <directory>… help="Directory to prepend" var=#true
__USAGE_EOF__
