#compdef ae
# @generated by usage-cli from /Users/ivuorinen/.dotfiles/local/bin/ae.usage.kdl
local curcontext="$curcontext"

_ae() {
  typeset -A opt_args
  local curcontext="$curcontext" cache_policy

  if ! type -p usage &> /dev/null; then
      echo >&2
      echo "Error: usage CLI not found. This is required for completions to work in ae." >&2
      echo "See https://usage.jdx.dev for more information." >&2
      return 1
  fi

  local spec_file="${TMPDIR:-/tmp}/usage__usage_spec_ae.spec"
  cat >| "$spec_file" <<'__USAGE_EOF__'
name ae
bin ae
about "Encrypt a file using age with GitHub SSH keys"
arg <file> help="File to encrypt"
__USAGE_EOF__
  local -a completions=()
  while IFS= read -r line; do
    completions+=("$line")
  done < <(command usage complete-word --shell zsh -f "$spec_file" -- "${words[@]}")
  _describe 'completions' completions -S ''
  return 0
}

if [ "$funcstack[1]" = "_ae" ]; then
    _ae "$@"
else
    compdef _ae ae
fi

