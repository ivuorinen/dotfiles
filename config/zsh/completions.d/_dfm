      echo >&2
      echo "Error: usage CLI not found. This is required for completions to work in dfm." >&2
      echo "See https://usage.jdx.dev for more information." >&2
      return 1
  fi

  local spec_file="${TMPDIR:-/tmp}/usage__usage_spec_dfm.spec"
  cat >| "$spec_file" <<'__USAGE_EOF__'
