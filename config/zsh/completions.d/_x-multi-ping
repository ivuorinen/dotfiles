bin x-multi-ping
about "Multi-protocol ping for IPv4 and IPv6"
flag --help help="Show help"
flag --verbose help="Verbose output"
flag --loop help="Loop indefinitely"
flag --forever help="Loop indefinitely (alias)"
flag --sleep help="Sleep between iterations (default: 1)" {
    arg <seconds>
}
arg <hostnames>… help="Hostnames to ping" var=#true
__USAGE_EOF__
  local -a completions=()
  while IFS= read -r line; do
    completions+=("$line")
  done < <(command usage complete-word --shell zsh -f "$spec_file" -- "${words[@]}")
  _describe 'completions' completions -S ''
