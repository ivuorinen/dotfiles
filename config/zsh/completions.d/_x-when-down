#compdef x-when-down
# @generated by usage-cli from /Users/ivuorinen/.dotfiles/local/bin/x-when-down.usage.kdl
local curcontext="$curcontext"

_x_when_down() {
  typeset -A opt_args
  local curcontext="$curcontext" cache_policy

  if ! type -p usage &> /dev/null; then
      echo >&2
      echo "Error: usage CLI not found. This is required for completions to work in x-when-down." >&2
      echo "See https://usage.jdx.dev for more information." >&2
      return 1
  fi

  local spec_file="${TMPDIR:-/tmp}/usage__usage_spec_x_when_down.spec"
  cat >| "$spec_file" <<'__USAGE_EOF__'
name x-when-down
bin x-when-down
about "Wait for host to go offline, then execute command"
arg <host> help="Host to monitor"
arg <command>… help="Command to execute when host is down" var=#true
__USAGE_EOF__
  local -a completions=()
  while IFS= read -r line; do
    completions+=("$line")
  done < <(command usage complete-word --shell zsh -f "$spec_file" -- "${words[@]}")
  _describe 'completions' completions -S ''
  return 0
}

if [ "$funcstack[1]" = "_x_when_down" ]; then
    _x_when_down "$@"
else
    compdef _x_when_down x-when-down
fi

