#compdef x-sonarcloud
# @generated by usage-cli from /Users/ivuorinen/.dotfiles/local/bin/x-sonarcloud.usage.kdl
local curcontext="$curcontext"

_x_sonarcloud() {
  typeset -A opt_args
  local curcontext="$curcontext" cache_policy

  if ! type -p usage &> /dev/null; then
      echo >&2
      echo "Error: usage CLI not found. This is required for completions to work in x-sonarcloud." >&2
      echo "See https://usage.jdx.dev for more information." >&2
      return 1
  fi

  local spec_file="${TMPDIR:-/tmp}/usage__usage_spec_x_sonarcloud.spec"
  cat >| "$spec_file" <<'__USAGE_EOF__'
name x-sonarcloud
bin x-sonarcloud
about "Fetch SonarCloud issues for LLM analysis"
flag --pr help="PR-specific issues" {
    arg <number>
}
flag --branch help="Branch-specific issues" {
    arg <name>
}
flag --org help="Organization name" {
    arg <org>
}
flag --project-key help="Project key" {
    arg <key>
}
flag --severities help="Filter by severity (BLOCKER,CRITICAL,MAJOR,MINOR,INFO)" {
    arg <severities>
}
flag --types help="Filter by type (BUG,VULNERABILITY,CODE_SMELL,SECURITY_HOTSPOT)" {
    arg <types>
}
flag --statuses help="Filter by status (OPEN,CONFIRMED,REOPENED)" {
    arg <statuses>
}
flag --resolved help="Include resolved issues"
flag "-h --help" help="Show help"
__USAGE_EOF__
  local -a completions=()
  while IFS= read -r line; do
    completions+=("$line")
  done < <(command usage complete-word --shell zsh -f "$spec_file" -- "${words[@]}")
  _describe 'completions' completions -S ''
  return 0
}

if [ "$funcstack[1]" = "_x_sonarcloud" ]; then
    _x_sonarcloud "$@"
else
    compdef _x_sonarcloud x-sonarcloud
fi

