local curcontext="$curcontext"

_x_localip() {
  typeset -A opt_args
  local curcontext="$curcontext" cache_policy

  if ! type -p usage &> /dev/null; then
      echo >&2
      echo "Error: usage CLI not found. This is required for completions to work in x-localip." >&2
      echo "See https://usage.jdx.dev for more information." >&2
      return 1
  fi

  local spec_file="${TMPDIR:-/tmp}/usage__usage_spec_x_localip.spec"
  cat >| "$spec_file" <<'__USAGE_EOF__'
name x-localip
bin x-localip
about "Display local IP addresses"
flag --help help="Show help"
flag --version help="Show version"
flag --ipv4 help="Show only IPv4 addresses"
flag --ipv6 help="Show only IPv6 addresses"
arg "[interface]" help="Specific network interface" required=#false
__USAGE_EOF__
  local -a completions=()
  while IFS= read -r line; do
    completions+=("$line")
  done < <(command usage complete-word --shell zsh -f "$spec_file" -- "${words[@]}")
  _describe 'completions' completions -S ''
  return 0
}

if [ "$funcstack[1]" = "_x_localip" ]; then
    _x_localip "$@"
else
    compdef _x_localip x-localip
fi

