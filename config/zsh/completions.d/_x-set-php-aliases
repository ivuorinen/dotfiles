_x_set_php_aliases() {
  typeset -A opt_args
  local curcontext="$curcontext" cache_policy

  if ! type -p usage &> /dev/null; then
      echo >&2
      echo "Error: usage CLI not found. This is required for completions to work in x-set-php-aliases." >&2
      echo "See https://usage.jdx.dev for more information." >&2
      return 1
  fi

  local spec_file="${TMPDIR:-/tmp}/usage__usage_spec_x_set_php_aliases.spec"
  cat >| "$spec_file" <<'__USAGE_EOF__'
name x-set-php-aliases
bin x-set-php-aliases
about "Cache PHP installations and generate shell aliases"
flag --prefix help="Show Homebrew prefix"
__USAGE_EOF__
  local -a completions=()
  while IFS= read -r line; do
    completions+=("$line")
  done < <(command usage complete-word --shell zsh -f "$spec_file" -- "${words[@]}")
  _describe 'completions' completions -S ''
  return 0
}

if [ "$funcstack[1]" = "_x_set_php_aliases" ]; then
    _x_set_php_aliases "$@"
else
    compdef _x_set_php_aliases x-set-php-aliases
fi

