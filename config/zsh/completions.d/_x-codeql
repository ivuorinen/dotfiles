#compdef x-codeql
# @generated by usage-cli from /Users/ivuorinen/.dotfiles/local/bin/x-codeql.usage.kdl
local curcontext="$curcontext"

_x_codeql() {
  typeset -A opt_args
  local curcontext="$curcontext" cache_policy

  if ! type -p usage &> /dev/null; then
      echo >&2
      echo "Error: usage CLI not found. This is required for completions to work in x-codeql." >&2
      echo "See https://usage.jdx.dev for more information." >&2
      return 1
  fi

  local spec_file="${TMPDIR:-/tmp}/usage__usage_spec_x_codeql.spec"
  cat >| "$spec_file" <<'__USAGE_EOF__'
name x-codeql
bin x-codeql
about "CodeQL security scanning wrapper"
flag --path help="Source path to analyze (default: current directory)" {
    arg <path>
}
flag --parallel help="Run language analyses in parallel"
flag "-h --help" help="Show help"
flag "-v --version" help="Show version"
__USAGE_EOF__
  local -a completions=()
  while IFS= read -r line; do
    completions+=("$line")
  done < <(command usage complete-word --shell zsh -f "$spec_file" -- "${words[@]}")
  _describe 'completions' completions -S ''
  return 0
}

if [ "$funcstack[1]" = "_x_codeql" ]; then
    _x_codeql "$@"
else
    compdef _x_codeql x-codeql
fi

