#compdef x-dc
# @generated by usage-cli from /Users/ivuorinen/.dotfiles/local/bin/x-dc.usage.kdl
local curcontext="$curcontext"

_x_dc() {
  typeset -A opt_args
  local curcontext="$curcontext" cache_policy

  if ! type -p usage &> /dev/null; then
      echo >&2
      echo "Error: usage CLI not found. This is required for completions to work in x-dc." >&2
      echo "See https://usage.jdx.dev for more information." >&2
      return 1
  fi

  local spec_file="${TMPDIR:-/tmp}/usage__usage_spec_x_dc.spec"
  cat >| "$spec_file" <<'__USAGE_EOF__'
name x-dc
bin x-dc
about "Create a directory with verbose output"
arg <path> help="Directory path to create"
__USAGE_EOF__
  local -a completions=()
  while IFS= read -r line; do
    completions+=("$line")
  done < <(command usage complete-word --shell zsh -f "$spec_file" -- "${words[@]}")
  _describe 'completions' completions -S ''
  return 0
}

if [ "$funcstack[1]" = "_x_dc" ]; then
    _x_dc "$@"
else
    compdef _x_dc x-dc
fi

