#compdef x-record
# @generated by usage-cli from /Users/ivuorinen/.dotfiles/local/bin/x-record.usage.kdl
local curcontext="$curcontext"

_x_record() {
  typeset -A opt_args
  local curcontext="$curcontext" cache_policy

  if ! type -p usage &> /dev/null; then
      echo >&2
      echo "Error: usage CLI not found. This is required for completions to work in x-record." >&2
      echo "See https://usage.jdx.dev for more information." >&2
      return 1
  fi

  local spec_file="${TMPDIR:-/tmp}/usage__usage_spec_x_record.spec"
  cat >| "$spec_file" <<'__USAGE_EOF__'
name x-record
bin x-record
about "Screen recording tool using ffmpeg"
arg <type> help="Recording type: gif or mkv"
arg <scope> help="Recording scope: size (window) or full (screen)"
__USAGE_EOF__
  local -a completions=()
  while IFS= read -r line; do
    completions+=("$line")
  done < <(command usage complete-word --shell zsh -f "$spec_file" -- "${words[@]}")
  _describe 'completions' completions -S ''
  return 0
}

if [ "$funcstack[1]" = "_x_record" ]; then
    _x_record "$@"
else
    compdef _x_record x-record
fi

