#compdef x-help
# @generated by usage-cli from /Users/ivuorinen/.dotfiles/local/bin/x-help.usage.kdl
local curcontext="$curcontext"

_x_help() {
  typeset -A opt_args
  local curcontext="$curcontext" cache_policy

  if ! type -p usage &> /dev/null; then
      echo >&2
      echo "Error: usage CLI not found. This is required for completions to work in x-help." >&2
      echo "See https://usage.jdx.dev for more information." >&2
      return 1
  fi

  local spec_file="${TMPDIR:-/tmp}/usage__usage_spec_x_help.spec"
  cat >| "$spec_file" <<'__USAGE_EOF__'
name x-help
bin x-help
about "Browse and display dotfiles documentation"
flag --source-only help="Show raw source instead of rendered output"
arg "[name]" help="Script name to look up (interactive fzf if omitted)" required=#false
__USAGE_EOF__
  local -a completions=()
  while IFS= read -r line; do
    completions+=("$line")
  done < <(command usage complete-word --shell zsh -f "$spec_file" -- "${words[@]}")
  _describe 'completions' completions -S ''
  return 0
}

if [ "$funcstack[1]" = "_x_help" ]; then
    _x_help "$@"
else
    compdef _x_help x-help
fi

