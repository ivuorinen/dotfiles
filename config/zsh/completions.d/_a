#compdef a
# @generated by usage-cli from /Users/ivuorinen/.dotfiles/local/bin/a.usage.kdl
local curcontext="$curcontext"

_a() {
  typeset -A opt_args
  local curcontext="$curcontext" cache_policy

  if ! type -p usage &> /dev/null; then
      echo >&2
      echo "Error: usage CLI not found. This is required for completions to work in a." >&2
      echo "See https://usage.jdx.dev for more information." >&2
      return 1
  fi

  local spec_file="${TMPDIR:-/tmp}/usage__usage_spec_a.spec"
  cat >| "$spec_file" <<'__USAGE_EOF__'
name a
bin a
version "1.1.0"
about "Encrypt and decrypt files or directories with age and SSH keys"
flag "-v --verbose" help="Print log messages to console"
flag --delete help="Delete original files after encryption"
flag "-f --force" help="Overwrite existing output files"
cmd encrypt help="Encrypt a file or directory" {
    alias e enc
    arg <target> help="File or directory to encrypt"
}
cmd decrypt help="Decrypt a file or directory" {
    alias d dec
    arg <target> help="File or directory to decrypt"
}
cmd help help="Show help"
cmd version help="Show version"
__USAGE_EOF__
  local -a completions=()
  while IFS= read -r line; do
    completions+=("$line")
  done < <(command usage complete-word --shell zsh -f "$spec_file" -- "${words[@]}")
  _describe 'completions' completions -S ''
  return 0
}

if [ "$funcstack[1]" = "_a" ]; then
    _a "$@"
else
    compdef _a a
fi

