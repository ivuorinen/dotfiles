#compdef php-switcher
# @generated by usage-cli from /Users/ivuorinen/.dotfiles/local/bin/php-switcher.usage.kdl
local curcontext="$curcontext"

_php_switcher() {
  typeset -A opt_args
  local curcontext="$curcontext" cache_policy

  if ! type -p usage &> /dev/null; then
      echo >&2
      echo "Error: usage CLI not found. This is required for completions to work in php-switcher." >&2
      echo "See https://usage.jdx.dev for more information." >&2
      return 1
  fi

  local spec_file="${TMPDIR:-/tmp}/usage__usage_spec_php_switcher.spec"
  cat >| "$spec_file" <<'__USAGE_EOF__'
name php-switcher
bin php-switcher
about "Switch between PHP versions installed via Homebrew"
flag --help help="Show help"
flag --installed help="List installed PHP versions"
flag --current help="Show currently active version"
flag --auto help="Auto-switch based on .php-version file"
arg "[version]" help="PHP version (e.g., 7.4, 8.0) or 'latest'" required=#false
__USAGE_EOF__
  local -a completions=()
  while IFS= read -r line; do
    completions+=("$line")
  done < <(command usage complete-word --shell zsh -f "$spec_file" -- "${words[@]}")
  _describe 'completions' completions -S ''
  return 0
}

if [ "$funcstack[1]" = "_php_switcher" ]; then
    _php_switcher "$@"
else
    compdef _php_switcher php-switcher
fi

