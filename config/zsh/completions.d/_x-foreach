#compdef x-foreach
# @generated by usage-cli from /Users/ivuorinen/.dotfiles/local/bin/x-foreach.usage.kdl
local curcontext="$curcontext"

_x_foreach() {
  typeset -A opt_args
  local curcontext="$curcontext" cache_policy

  if ! type -p usage &> /dev/null; then
      echo >&2
      echo "Error: usage CLI not found. This is required for completions to work in x-foreach." >&2
      echo "See https://usage.jdx.dev for more information." >&2
      return 1
  fi

  local spec_file="${TMPDIR:-/tmp}/usage__usage_spec_x_foreach.spec"
  cat >| "$spec_file" <<'__USAGE_EOF__'
name x-foreach
bin x-foreach
about "Run a command in each directory from a listing"
arg <listing_cmd> help="Command that lists directories"
arg <command>… help="Command to run in each directory" var=#true
__USAGE_EOF__
  local -a completions=()
  while IFS= read -r line; do
    completions+=("$line")
  done < <(command usage complete-word --shell zsh -f "$spec_file" -- "${words[@]}")
  _describe 'completions' completions -S ''
  return 0
}

if [ "$funcstack[1]" = "_x_foreach" ]; then
    _x_foreach "$@"
else
    compdef _x_foreach x-foreach
fi

