#compdef x-pr-comments
# @generated by usage-cli from /Users/ivuorinen/.dotfiles/local/bin/x-pr-comments.usage.kdl
local curcontext="$curcontext"

_x_pr_comments() {
  typeset -A opt_args
  local curcontext="$curcontext" cache_policy

  if ! type -p usage &> /dev/null; then
      echo >&2
      echo "Error: usage CLI not found. This is required for completions to work in x-pr-comments." >&2
      echo "See https://usage.jdx.dev for more information." >&2
      return 1
  fi

  local spec_file="${TMPDIR:-/tmp}/usage__usage_spec_x_pr_comments.spec"
  cat >| "$spec_file" <<'__USAGE_EOF__'
name x-pr-comments
bin x-pr-comments
about "Fetch PR comments formatted for LLM analysis"
flag --help help="Show help"
arg <pr> help="PR number or full GitHub URL"
__USAGE_EOF__
  local -a completions=()
  while IFS= read -r line; do
    completions+=("$line")
  done < <(command usage complete-word --shell zsh -f "$spec_file" -- "${words[@]}")
  _describe 'completions' completions -S ''
  return 0
}

if [ "$funcstack[1]" = "_x_pr_comments" ]; then
    _x_pr_comments "$@"
else
    compdef _x_pr_comments x-pr-comments
fi

