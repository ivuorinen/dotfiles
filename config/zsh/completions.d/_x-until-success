#compdef x-until-success
# @generated by usage-cli from /Users/ivuorinen/.dotfiles/local/bin/x-until-success.usage.kdl
local curcontext="$curcontext"

_x_until_success() {
  typeset -A opt_args
  local curcontext="$curcontext" cache_policy

  if ! type -p usage &> /dev/null; then
      echo >&2
      echo "Error: usage CLI not found. This is required for completions to work in x-until-success." >&2
      echo "See https://usage.jdx.dev for more information." >&2
      return 1
  fi

  local spec_file="${TMPDIR:-/tmp}/usage__usage_spec_x_until_success.spec"
  cat >| "$spec_file" <<'__USAGE_EOF__'
name x-until-success
bin x-until-success
about "Retry a command until it succeeds"
flag --sleep help="Sleep between retries" {
    arg <seconds>
}
flag --help help="Show help"
arg <command>… help="Command to run" var=#true
__USAGE_EOF__
  local -a completions=()
  while IFS= read -r line; do
    completions+=("$line")
  done < <(command usage complete-word --shell zsh -f "$spec_file" -- "${words[@]}")
  _describe 'completions' completions -S ''
  return 0
}

if [ "$funcstack[1]" = "_x_until_success" ]; then
    _x_until_success "$@"
else
    compdef _x_until_success x-until-success
fi

