#!/usr/bin/env bash

# Color the grep output
alias grep="grep --color"

# ls family: eza with git annotations inside a work tree, system ls otherwise.
# Mirrors the fish eza_git wrapper so ls/l/ll/lsa match across shells.
if x-have eza; then
  eza_git()
  {
    if git rev-parse --is-inside-work-tree &> /dev/null; then
      eza --group-directories-first --icons=always --smart-group --git "$@"
    else
      eza --group-directories-first --icons=always --smart-group "$@"
    fi
  }
  alias ls='eza_git'
  alias l='eza_git'
  alias ll='eza_git -l'
  alias lsa='eza_git -al'
else
  alias ls='command ls'
  alias l='command ls'
  alias ll='command ls -lh'
  alias lsa='command ls -lah'
fi

# gopass password manager shortcut (resolves via PATH / mise shim)
x-have gopass && {
  alias p="gopass"
}

# Git shortcuts (aligned with fish alias.fish; override the OMZ git plugin)
alias gau='git add -u'
alias gaa='git add -A'
alias gcv='git commit -v'
alias gst='git status -sbv'
alias glg='git log'
alias gwa='git worktree add'
alias gwr='git worktree remove'
alias gwl='git worktree list'
alias gl='git log --pretty=format:"%C(yellow)%h%Creset %C(cyan)%an%Creset %Cgreen(%ad)%Creset %s" --date=short'

# Easier navigation: .., ..., ....
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."

# cd to git root directory (logic lives in local/bin/x-git-root)
alias cdgr='cd "$(x-git-root)"'

# interesting folders, and shortcuts (targets aligned with fish alias.fish)
alias .b='cd $XDG_BIN_HOME'
alias .c='cd ~/Code'
alias .d='cd ~/.dotfiles'
alias .l='cd ~/.local'
alias .o='cd ~/Code/ivuorinen/obsidian/'
alias .s='cd ~/Code/s'
alias .p='cd ~/Code/ivuorinen'

# Prevent common typos
alias cd..="cd .."
alias sl="ls"

# macOS-specific commands live in local/bin/x-* (run `x <name>`):
#   localip -> x-localip                 show/hide -> x-macos-show / x-macos-hide
#   flush   -> x-macos-flush             flushdns  -> x-macos-flushdns
#   updatedb -> x-macos-updatedb

# Date helpers (datetime/timestamp moved to scripts — run `x datetime` / `x timestamp`)
alias isodate="date +'%Y-%m-%d'"

# nvim aliases
alias v='nvim'
alias vi='nvim'
alias vim='nvim'

# .NET shortcuts (aligned with fish alias.fish abbreviations)
alias dt='dotnet test'
alias dw='dotnet watch'

# onefetch repo stats (aligned with fish alias.fish abbreviation)
x-have onefetch && {
  alias stats="onefetch --nerd-fonts --true-color never"
}

# xdg-ninja aliases for better experience
alias xdg='xdg-ninja --skip-ok --skip-unsupported'

# watch with: differences, precise, beep and color
alias watchx='watch -dpbc'
# directory usage, return only the total
alias dn='du -chd1'
# Mirror stdout to stderr, useful for seeing data going through a pipe
alias peek='tee /dev/stderr'

# Opens dotfiles with $EDITOR
alias zedit='$EDITOR ~/.dotfiles'
# Open irssi with my configurations
alias irssi='irssi --config=$XDG_CONFIG_HOME/irssi/config --home=$XDG_CONFIG_HOME/irssi'
# Configures wget to use correct wget-hsts file
alias wget='wget --hsts-file=$XDG_DATA_HOME/wget-hsts'
# Render markdown with the terminal-palette style (logic in local/bin/x-glow)
alias glow='x-glow'

# Guarded so re-sourcing this file (e.g. zshrc re-applies it after antidote so
# our git aliases win over the OMZ git plugin) does not re-load secret files.
if [ -z "${X_ALIAS_FILES_SOURCED:-}" ]; then
  X_ALIAS_FILES=(
    "$HOME/.config/alias-secret"
    "$HOME/.config/alias-$(hostname)"
    "$HOME/.config/alias-$(hostname)-secret"
  )
  for aliasFile in "${X_ALIAS_FILES[@]}"; do
    # shellcheck source=$HOME/.config/alias-secret
    [ -f "$aliasFile" ] && source "$aliasFile" && msgr ok "Sourced $aliasFile"
  done
  unset X_ALIAS_FILES
  X_ALIAS_FILES_SOURCED=1
fi
