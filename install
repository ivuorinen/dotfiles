#!/usr/bin/env bash
set -e

CONFIG="install.conf.yaml"
LINKS_CONFIG="dotbot-links.yaml"
DOTBOT_DIR="tools/dotbot"

DOTBOT_BIN="bin/dotbot"
BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTBOT_BIN_PATH="${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}"
DOTBOT_HOST="$(hostname -s)"

LINKS_ONLY=false
DOTBOT_ARGS=()
for arg in "$@"; do
  case "$arg" in
    --links) LINKS_ONLY=true ;;
    *) DOTBOT_ARGS+=("$arg") ;;
  esac
done

# Run every executable in hosts/<host>/<phase>.d in alphabetical order, when the
# directory exists. `before.d` runs ahead of the main install.conf, `after.d`
# once everything else is done. A failing hook is logged but never aborts the
# install. Hooks must be executable; non-executable files are skipped with a
# warning. DOTFILES is exported so hooks can locate the repo.
run_host_hooks()
{
  local phase hook_dir hook
  phase="$1"
  hook_dir="${BASEDIR}/hosts/${DOTBOT_HOST}/${phase}.d"
  if [ -z "${DOTBOT_HOST}" ] || [ ! -d "${hook_dir}" ]; then
    return 0
  fi
  echo "-> Running ${phase}.d hooks for host ${DOTBOT_HOST}"
  for hook in "${hook_dir}"/*; do
    [ -e "${hook}" ] || continue # empty dir: skip the literal glob
    if [ ! -x "${hook}" ]; then
      echo "(!) Skipping non-executable ${phase}.d hook: ${hook}" >&2
      continue
    fi
    echo "   -> ${hook##*/}"
    "${hook}" || echo "(!) ${phase}.d hook failed (continuing): ${hook}" >&2
  done
}

export DOTFILES="${BASEDIR}"

cd "${BASEDIR}"
git -C "${DOTBOT_DIR}" submodule sync --quiet --recursive
git submodule update --init --recursive "${DOTBOT_DIR}"

if [ "$LINKS_ONLY" = true ]; then
  "${DOTBOT_BIN_PATH}" \
    -d "${BASEDIR}" \
    --plugin-dir=tools/dotbot-include \
    -c "${LINKS_CONFIG}" \
    "${DOTBOT_ARGS[@]}"
  exit 0
fi

run_host_hooks before

"${DOTBOT_BIN_PATH}" \
  -d "${BASEDIR}" \
  --plugin-dir=tools/dotbot-include \
  -c "${CONFIG}" \
  "${DOTBOT_ARGS[@]}"

if [ "${DOTBOT_HOST}" != "" ]; then
  DOTBOT_HOST_CONFIG="${BASEDIR}/hosts/${DOTBOT_HOST}/${CONFIG}"
  echo "-> Trying if host config can be found: ${DOTBOT_HOST_CONFIG}"
  [ -r "$DOTBOT_HOST_CONFIG" ] && [ -f "$DOTBOT_HOST_CONFIG" ] \
    && echo "(!) Found $DOTBOT_HOST_CONFIG" \
    && "$DOTBOT_BIN_PATH" \
      -d "$BASEDIR" \
      --plugin-dir=tools/dotbot-include \
      -c "$DOTBOT_HOST_CONFIG" \
      "${DOTBOT_ARGS[@]}"
fi

run_host_hooks after
