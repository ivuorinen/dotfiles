#!/usr/bin/env bash
#USAGE about "Dotfiles manager and install helper"
#USAGE author "Ismo Vuorinen"
#USAGE cmd "help" help="Show help"
#
# Dotfiles manager and install helper — thin git-style dispatcher.
#
# `dfm <section> <args>` resolves and execs `dfm-<section>` (sibling of
# this script first, then $PATH), mirroring how git finds git-<command>.
# The per-section logic lives in the dfm-* scripts; shared helpers live
# in the sourced (non-executable) dfm-lib.
#
# (c) Ismo Vuorinen <https://github.com/ivuorinen> 2022
# Licensed under MIT, see LICENSE
#
# vim: ft=bash ts=2 sw=2 et
# shellcheck source-path=$HOME/.dotfiles/local/bin

# Directory where the dfm scripts REALLY live — also the home of dfm-lib and
# every dfm-* subcommand. We resolve $0 through any symlinks first: when dfm is
# invoked via a ~/.local/bin/dfm symlink (a prior install), a plain
# dirname "$0" would yield ~/.local/bin, which need not contain newly added
# dfm-* siblings (or even dfm-lib) before `./install` links them. Following the
# symlink chain to the repo's local/bin makes `dfm <new-sub>` work the moment
# the file is dropped in — no re-link needed — and resolving here (before $PATH)
# keeps the script's own folder authoritative. readlink is used without -f for
# macOS/BSD portability.
_dfm_src="$0"
while [ -h "$_dfm_src" ]; do
  _dfm_link_dir=$(
    unset CDPATH
    cd -P -- "$(dirname -- "$_dfm_src")" && pwd
  )
  _dfm_src=$(readlink "$_dfm_src")
  case "$_dfm_src" in
    /*) ;;
    *) _dfm_src="$_dfm_link_dir/$_dfm_src" ;;
  esac
done
_dfm_selfdir=$(
  unset CDPATH
  cd -P -- "$(dirname -- "$_dfm_src")" && pwd
)

# shellcheck source=local/bin/dfm-lib
if ! source "$_dfm_selfdir/dfm-lib"; then
  echo "dfm: cannot load $_dfm_selfdir/dfm-lib (broken install?)" >&2
  exit 1
fi

# Sections listed in the top-level help, in display order. `tests` is
# intentionally omitted — it is an internal visual-test helper, still
# reachable as `dfm tests` because dfm-tests exists on disk.
DFM_SECTIONS=(install secrets cleanup apt brew check dotfiles docs scripts helpers)

# Display main usage information by asking each subcommand to print its
# own menu (invoking it with no arguments hits its menu_builder branch).
usage()
{
  # Bootstrap (env + msgr) is deferred to the usage/unknown paths: the
  # dispatch fast-path execs the subcommand, which bootstraps itself, so
  # sourcing shared.sh/msgr here avoids doing it twice on every call.
  dfm_bootstrap
  echo ""
  msgr prompt "Usage: $SCRIPT <section> <command>"
  echo "  Empty <command> prints <section> help."
  echo ""
  local s
  for s in "${DFM_SECTIONS[@]}"; do
    "$_dfm_selfdir/dfm-$s"
    echo ""
  done
}

# Parse the section argument and exec the matching dfm-* subcommand.
main()
{
  local sub="${1:-}"
  [[ $# -gt 0 ]] && shift

  case "$sub" in
    "" | help | -h | --help)
      usage
      return 0
      ;;
  esac

  # Sibling-first lookup, then $PATH (git-style). Both branches require an
  # *executable* target: `command -v` returns a non-executable file when it
  # is first on $PATH (e.g. the 644 dfm-lib, which lives in a PATH dir), and
  # exec-ing it fails with "Permission denied" instead of falling through to
  # usage. The -x guard keeps the non-executable dfm-lib undispatchable.
  local cand="$_dfm_selfdir/dfm-$sub"
  if [[ -x "$cand" ]]; then
    exec "$cand" "$@"
  fi
  local resolved
  resolved=$(command -v "dfm-$sub" 2> /dev/null)
  if [[ -n "$resolved" && -x "$resolved" ]]; then
    exec "$resolved" "$@"
  fi

  # Unknown section: preserve the historical behaviour of printing the
  # full usage and exiting 0 (a bare typo should not be a hard error).
  usage
  return 0
}

main "$@"
