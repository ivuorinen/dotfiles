#!/usr/bin/env bash
# tv-preview — file preview dispatcher for television cables.
# Renders markdown with glow; falls back to bat for everything else.
# Falls back to bat when glow is not installed.

set -uo pipefail

file="$1"

case "$file" in
  *.md | *.MD | *.markdown | *.mkd)
    if command -v glow > /dev/null 2>&1; then
      # terminal.json uses the active terminal palette, so it tracks
      # dark/light automatically — no need to switch styles by theme-mode.
      style="${XDG_CONFIG_HOME:-$HOME/.config}/glow/terminal.json"
      if [ -f "$style" ]; then
        glow -s "$style" -- "$file"
      else
        glow -- "$file"
      fi
    else
      bat -n --color=always -- "$file"
    fi
    ;;
  *)
    bat -n --color=always -- "$file"
    ;;
esac
