#!/usr/bin/env bash
#USAGE about "Print a solid separator line in the terminal"
# Simple script to output a solid line in the terminal
# Useful for marking the end of a task in your bash log
# Inspired by @LuRsT's script of the same name
# Can be called directly, or source'd in *rc file
#
# Licensed under MIT, (C) Alicia Sykes 2022
# See: https://github.com/Lissy93/dotfiles
#
# Modified by Ismo Vuorinen <https://github.com/ivuorinen> 2023

# Determine width of terminal: ask the tty itself when we have one
# (exported COLUMNS can be stale after a resize), else COLUMNS, else 80
hr_col_count=""
if [ -t 1 ]; then
  # No stderr redirect: inside $() tput's stdout is a pipe, so ncurses
  # measures the terminal via stderr — silencing it forces the 80 default
  hr_col_count="$(tput cols)"
fi
hr_col_count="${hr_col_count:-${COLUMNS:-}}"
case "$hr_col_count" in
  '' | *[!0-9]*) hr_col_count=80 ;;
esac

# Colors
CLR_RED="\033[1;31m"
hr_color="${hr_color:=$CLR_RED}"
hr_reset="\033[0m"

# Prints the HR line
hr_draw_char()
{
  local CHAR="$1" LINE
  printf -v LINE "%*s" "$((hr_col_count - 3))" ""
  LINE="${LINE// /${CHAR}}"
  echo -e "${hr_color}${LINE:0:${hr_col_count}}${hr_reset}"
}

# Passes param and calls hr()
hr()
{
  for WORD in "${@:--}"; do
    hr_draw_char "$WORD"
  done
}

hr "$@"
