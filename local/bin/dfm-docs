#!/usr/bin/env bash
#USAGE cmd "docs" help="Show documentation from docs/" {
#USAGE   arg "[file]" help="Doc file name (docs/<file>.md)"
#USAGE }
#
# @description Show documentation (dfm docs)
# dfm docs — show documentation from docs/*.md.
#
# vim: ft=bash ts=2 sw=2 et
# shellcheck source-path=$HOME/.dotfiles/local/bin

_dfm_dir=$(
  unset CDPATH
  cd -- "$(dirname -- "$0")" && pwd
)
# shellcheck source=local/bin/dfm-lib
if ! source "$_dfm_dir/dfm-lib"; then
  echo "${0##*/}: cannot load dfm-lib (broken install?)" >&2
  exit 1
fi
dfm_bootstrap_for "$@"

# Show a documentation file from docs/. The menu is built by scanning
# docs/*.md (top level only — docs/audit/ is never listed) and using
# each file's first "# " header as its description.
dfm_docs()
{
  USAGE_PREFIX="$SCRIPT docs <file>"
  local docs_dir="$DOTFILES/docs"

  if [[ -z ${1:-} ]]; then
    local MENU=() f name desc
    for f in "$docs_dir"/*.md; do
      [[ -f $f ]] || continue
      name=${f##*/}
      name=${name%.md}
      desc=$(awk '/^# /{ sub(/^# /, ""); print; exit }' "$f")
      MENU+=("$name:${desc:-$name}")
    done
    menu_builder "$USAGE_PREFIX" "${MENU[@]}"
    return
  fi

  local name=${1##*/}
  local path="$docs_dir/${name%.md}.md"
  if [[ ! -f $path ]]; then
    echo "Documentation not found: $path" >&2
    return 1
  fi

  # x-glow applies the terminal-palette style so glow follows the theme
  if command -v glow > /dev/null 2>&1; then
    "$_dfm_dir/x-glow" "$path"
  elif command -v bat > /dev/null 2>&1; then
    bat "$path"
  else
    cat "$path"
  fi
}

dfm_docs "$@"
