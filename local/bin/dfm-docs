#!/usr/bin/env bash
#USAGE cmd "docs" help="Show generated documentation" {
#USAGE   cmd "aliases" help="Show shell aliases documentation"
#USAGE   cmd "nvim" help="Show nvim keybindings documentation"
#USAGE   cmd "tmux" help="Show tmux keybindings documentation"
#USAGE   cmd "wezterm" help="Show wezterm keybindings documentation"
#USAGE }
#
# @description Show generated documentation (dfm docs)
# dfm docs — show generated documentation.
#
# vim: ft=bash ts=2 sw=2 et
# shellcheck source-path=$HOME/.dotfiles/local/bin

_dfm_dir=$(
  unset CDPATH
  cd -- "$(dirname -- "$0")" && pwd
)
# shellcheck source=local/bin/dfm-lib
if ! source "$_dfm_dir/dfm-lib"; then
  echo "${0##*/}: cannot load dfm-lib (broken install?)" >&2
  exit 1
fi
dfm_bootstrap_for "$@"

# Show a generated documentation file. Generators live under `dfm helpers`.
dfm_docs()
{
  USAGE_PREFIX="$SCRIPT docs <command>"
  MENU=(
    "aliases:Show shell aliases documentation"
    "nvim:Show nvim keybindings documentation"
    "tmux:Show tmux keybindings documentation"
    "wezterm:Show wezterm keybindings documentation"
  )

  local file
  case "${1:-}" in
    aliases) file="aliases.md" ;;
    nvim) file="nvim-keybindings.md" ;;
    tmux) file="tmux-keybindings.md" ;;
    wezterm) file="wezterm-keybindings.md" ;;
    *)
      menu_builder "$USAGE_PREFIX" "${MENU[@]}"
      return
      ;;
  esac

  local path="$DOTFILES/docs/$file"
  if [[ ! -f $path ]]; then
    echo "Documentation not found: $path (generate it with 'dfm helpers docs-$1')" >&2
    return 1
  fi
  cat "$path"
}

dfm_docs "$@"
