#!/usr/bin/env bash
#USAGE about "Run a command in each directory from a listing"
#USAGE arg "<listing_cmd>" help="Command that lists directories"
#USAGE arg "<command>" help="Command to run in each directory" var=#true
#
# Run a command in each directory matching a pattern.
#
# Usage: x-foreach <listing-command> <command> [args...]
#   x-foreach "ls -d */" "git status"   # quoted command string (evaled)
#   x-foreach "ls -d */" git status     # command + args
#
# Source: https://github.com/mvdan/dotfiles/blob/master/.bin/foreach

set -euo pipefail

# x-hr lives next to this script; on an uninstalled checkout (CI, fresh
# clone) it is not on PATH yet — resolve it from this directory.
command -v x-hr > /dev/null 2>&1 \
  || PATH="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd):$PATH"

if [ $# -lt 2 ]; then
  cat << EOF
Usage: ${0##*/} <listing-command> <command> [args...]

Examples:
  ${0##*/} "ls -d */" "git status"     # quoted command string (evaled)
  ${0##*/} "ls -d */" git status       # command + args
  ${0##*/} "fd -t d -d 1" "git pull"   # any listing command works
EOF
  exit 1
fi

listing=$1
shift

# shellcheck disable=SC2294  # eval is intentional: listing is a trusted owner-supplied command string
for dir in $(eval "$listing"); do
  (
    echo "$dir"
    echo
    cd "$dir" || exit 1
    if [ $# -eq 1 ]; then
      # Single quoted command string: eval so "git status" works
      eval "$1"
    else
      "$@"
    fi
  )
  x-hr
done
