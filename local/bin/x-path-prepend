#!/usr/bin/env bash
#USAGE about "Prepend directories to PATH"
#USAGE arg "<directory>" help="Directories to prepend" var=#true
#
# Thin wrapper — delegates to x-path prepend.
# Can be sourced (PATH changes propagate) or executed.
#
# Usage: x-path-prepend <directory1> [<directory2> ...]
#
# Author: Ismo Vuorinen <https://github.com/ivuorinen> 2024
# License: MIT

VERBOSE="${VERBOSE:-0}"

_xp_dir="${BASH_SOURCE[0]:-$0}"
case $_xp_dir in */*) _xp_dir="${_xp_dir%/*}" ;; *) _xp_dir=. ;; esac
# shellcheck source=./x-path
. "$_xp_dir/x-path"
unset _xp_dir

normalize_path_var
do_prepend "$@"
