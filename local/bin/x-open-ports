#!/usr/bin/env bash
#USAGE about "List open ports in Markdown or JSON format"
#USAGE flag "--json" help="Output in JSON format"
#USAGE flag "--help" help="Show help"
#
# List open (listened) ports in Markdown or JSON format.
#
# Modified by:     Ismo Vuorinen <https://github.com/ivuorinen> 2020, 2025
# Originally from: https://www.commandlinefu.com/commands/view/8951
# Original author: https://www.commandlinefu.com/commands/by/wickedcpj

set -euo pipefail

FORMAT="markdown"

SCRIPT_NAME="${0##*/}"

# Function to print help message ($1: exit code, default 0)
print_help()
{
  cat << EOF
Usage: $SCRIPT_NAME [OPTIONS]

List open (listened) ports in a formatted table (Markdown) or JSON.

Options:
  --json       Output results in JSON format instead of Markdown
  --help       Show this help message

Examples:
  $SCRIPT_NAME         # List open ports as a Markdown table
  $SCRIPT_NAME --json  # List open ports in JSON format

EOF
  exit "${1:-0}"
}

# Function to print the Markdown table header
print_header()
{
  echo "| User             | Command                    | PID      | Port    |"
  echo "|------------------|----------------------------|----------|---------|"
}

# Function to list open ports using lsof
list_open_ports_lsof()
{
  lsof -i -P -n -sTCP:LISTEN +c 0 2> /dev/null | awk '
    NR > 1 {
      port = $9
      sub(/.*:/, "", port)  # Extract port number
      printf "| %-16s | %-26s | %-8s | %-7s |\n", substr($3, 1, 16), substr($1, 1, 26), substr($2, 1, 8), port
    }
  ' | sort -t'|' -k5,5n | uniq
}

# Function to list open ports using ss (alternative)
list_open_ports_ss()
{
  ss -ltpn 2> /dev/null | awk '
    NR > 1 {
      split($5, addr, ":")
      port = addr[length(addr)]
      user = $1
      cmd = $7
      sub(/users:\(\(/, "", cmd)  # Cleanup command
      sub(/\)\)/, "", cmd)
      # POSIX awk: 3-arg match() is a gawk extension
      pid = "-"
      if (match(cmd, /pid=[0-9]+/)) pid = substr(cmd, RSTART + 4, RLENGTH - 4)
      printf "| %-16s | %-26s | %-8s | %-7s |\n", substr(user, 1, 16), substr(cmd, 1, 26), substr(pid, 1, 8), port
    }
  ' | sort -t'|' -k5,5n | uniq
}

# Function to print JSON output
list_open_ports_json()
{
  # Rows are prefixed with "<port>\t" as a sort key, then the key is cut
  # away — sorting the JSON text itself has no meaningful numeric field.
  if command -v lsof &> /dev/null; then
    lsof -i -P -n -sTCP:LISTEN +c 0 2> /dev/null | awk '
      NR > 1 {
        port = $9
        sub(/.*:/, "", port)  # Extract port number
        printf "%s\t{\"user\": \"%s\", \"command\": \"%s\", \"pid\": \"%s\", \"port\": \"%s\"},\n", port, $3, $1, $2, port
      }
    ' | sort -n | cut -f2- | uniq | sed '$ s/,$//'
  elif command -v ss &> /dev/null; then
    ss -ltpn 2> /dev/null | awk '
      NR > 1 {
        split($5, addr, ":")
        port = addr[length(addr)]
        user = $1
        cmd = $7
        sub(/users:\(\(/, "", cmd)
        sub(/\)\)/, "", cmd)
        # POSIX awk: 3-arg match() is a gawk extension
        pid = "-"
        if (match(cmd, /pid=[0-9]+/)) pid = substr(cmd, RSTART + 4, RLENGTH - 4)
        printf "%s\t{\"user\": \"%s\", \"command\": \"%s\", \"pid\": \"%s\", \"port\": \"%s\"},\n", port, user, cmd, pid, port
      }
    ' | sort -n | cut -f2- | uniq | sed '$ s/,$//'
  else
    echo "[]"
  fi
}

# Function to determine available command
list_open_ports()
{
  if [[ "$FORMAT" == "json" ]]; then
    echo "["
    list_open_ports_json
    echo "]"
  else
    print_header
    if command -v lsof &> /dev/null; then
      list_open_ports_lsof
    elif command -v ss &> /dev/null; then
      list_open_ports_ss
    else
      echo "**Error:** Neither 'lsof' nor 'ss' is available."
      exit 1
    fi
  fi
}

# Main function
main()
{
  case "${1:-}" in
    --json)
      FORMAT="json"
      ;;
    --help)
      print_help
      ;;
    "") ;;
    *)
      echo "Unknown option: $1" >&2
      print_help 1
      ;;
  esac

  list_open_ports
  echo ""
}

main "$@"
