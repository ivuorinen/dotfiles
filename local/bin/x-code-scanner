#!/usr/bin/env bash
# @description Run the GitLab code quality scanner on the current directory
#USAGE about "Run the GitLab code quality scanner on the current directory"

set -euo pipefail

exec docker run \
  --env SOURCE_CODE="$PWD" \
  --volume "$PWD":/code \
  --volume /var/run/docker.sock:/var/run/docker.sock \
  "registry.gitlab.com/gitlab-org/ci-cd/codequality:${CODEQUALITY_VERSION:-latest}" \
  /code
