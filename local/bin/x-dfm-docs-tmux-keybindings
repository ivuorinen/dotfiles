#!/usr/bin/env bash
#USAGE about "Update tmux keybindings documentation"
#
# x-dfm-docs-tmux-keybindings
# Regenerates docs/tmux-keybindings.md from `tmux list-keys`, covering
# EVERY registered binding in EVERY key table (built-in defaults
# included), grouped by table. Run via `dfm docs tmux`.
#
# Author: Ismo Vuorinen <https://github.com/ivuorinen> 2024
# shellcheck source=./../../config/shared.sh
source "${DOTFILES}/config/shared.sh"

# Enable verbosity with VERBOSE=1
VERBOSE="${VERBOSE:-0}"

# Tables listed first, in this order; any other tables tmux reports are
# appended afterwards (sorted) so nothing is ever dropped.
TMUX_PREFERRED_TABLES=(prefix root copy-mode copy-mode-vi)

# Check if tmux is installed
check_tmux_installed()
{
  if ! x-have tmux; then
    msg_err "tmux not found"
  fi
}

# Print every key table tmux knows about, one per line. The table name is
# the token right after the FIRST `-T`; `break` stops a command's own
# `-T` (e.g. `display-menu -T ...`) from being mistaken for the table.
tmux_key_tables()
{
  tmux list-keys \
    | awk '{ for (i = 1; i <= NF; i++) if ($i == "-T") { print $(i + 1); break } }' \
    | sort -u
}

# Emit "<key>  <description>" for every binding in the given key table.
#
# The description is tmux's own note (`list-keys -N`) when the binding has
# one, otherwise the bound command (plain `list-keys`, so note-less
# bindings are still listed). Two `list-keys` forms are merged: `-N`
# prints notes with the key UNescaped (`"`), while the full form escapes
# it (`\"`), so the key is normalised (one leading backslash stripped)
# before lookup and for display.
#
# Mouse / wheel / click events (MouseDown*, WheelUp*, DoubleClick*, …) are
# dropped — they are not useful in a key reference.
format_table_bindings()
{
  local table="$1"
  # The notes stream is prefixed with a "__NOTES__" sentinel so it is
  # never empty: an empty first file would make `NR == FNR` stay true for
  # the second file too (a classic awk pitfall), and tables with no notes
  # (root, copy-mode, …) would render nothing.
  awk '
    # Pass 1: notes from `list-keys -N` — "<key> <note...>".
    NR == FNR {
      if ($0 == "__NOTES__") next
      k = $1
      sub(/^\\/, "", k)
      $1 = ""
      sub(/^[ \t]+/, "")
      note[k] = $0
      next
    }
    # Pass 2: every binding — "bind-key [-r|-n] -T <table> <key> <cmd...>".
    {
      i = 1
      if ($i == "bind-key") i++
      if ($i == "-r" || $i == "-n") i++
      if ($i == "-T") i += 2
      key = $i
      i++
      cmd = ""
      for (; i <= NF; i++) cmd = cmd (cmd == "" ? "" : " ") $i

      if (key ~ /Mouse|Wheel|Click/) next

      sub(/^\\/, "", key)
      printf "%-22s %s\n", key, (key in note) ? note[key] : cmd
    }
  ' <(
    printf '__NOTES__\n'
    tmux list-keys -N -T "$table" 2> /dev/null
  ) <(tmux list-keys -T "$table")
}

# Print the key tables in display order: the preferred ones first (when
# present), then any remaining tables in sorted order.
ordered_tmux_tables()
{
  local all table pref
  all=$(tmux_key_tables)

  for pref in "${TMUX_PREFERRED_TABLES[@]}"; do
    grep -qxF "$pref" <<< "$all" && printf '%s\n' "$pref"
  done

  while IFS= read -r table; do
    [[ -z "$table" ]] && continue
    for pref in "${TMUX_PREFERRED_TABLES[@]}"; do
      [[ "$table" == "$pref" ]] && continue 2
    done
    printf '%s\n' "$table"
  done <<< "$all"
}

# Generate tmux keybindings documentation, one fenced section per table.
generate_tmux_keybindings()
{
  local out="$1"
  local table

  {
    printf '# tmux keybindings\n\n'
    printf 'Leader: `<ctrl><space>`\n\n'
    printf 'Every registered binding in every key table, generated by '
    printf '`dfm docs tmux`\nfrom `tmux list-keys`. Each entry shows the '
    printf "binding's note when it has\none "
    printf '(`bind-key -N`), otherwise the bound command. Built-in '
    printf 'defaults are\nincluded; mouse and wheel events are omitted.\n'

    while IFS= read -r table; do
      [[ -z "$table" ]] && continue
      printf '\n## %s\n\n```txt\n' "$table"
      format_table_bindings "$table"
      printf '```\n'
    done < <(ordered_tmux_tables)
  } > "$out"

  # Post-process: generalize expanded $HOME back to a literal "$HOME" so
  # the doc is identical on every machine, then strip the tmux plugin
  # install path — it is the same for every plugin binding and adds no
  # information (e.g. "$HOME/.local/share/tmux/plugins/tpm/..." -> "tpm/...").
  local tmp
  tmp=$(mktemp)
  if [[ -n "${HOME:-}" ]]; then
    sed -e "s#${HOME}#\$HOME#g" \
      -e 's#\$HOME/\.local/share/tmux/plugins/##g' \
      "$out" > "$tmp"
  else
    sed -e 's#\$HOME/\.local/share/tmux/plugins/##g' "$out" > "$tmp"
  fi
  mv "$tmp" "$out"
}

# Main function
main()
{
  check_tmux_installed

  local tmux_keybindings_docs="$DOTFILES/docs/tmux-keybindings.md"
  msg "Outputting tmux keybindings to $tmux_keybindings_docs"
  generate_tmux_keybindings "$tmux_keybindings_docs"
  msg "Done!"
}

main "$@"
