#!/usr/bin/env bash
#USAGE about "Ping multiple hosts and display results"
#USAGE flag "--help" help="Show help"
#USAGE flag "--loop" help="Loop indefinitely"
#USAGE flag "--forever" help="Loop indefinitely (alias)"
#USAGE flag "--sleep <seconds>" help="Sleep between iterations (default: 1)"
#USAGE arg "<hostnames>" help="Hostnames to ping" var=#true
# x-multi-ping: Multi-protocol ping wrapper in Bash
#
# Description:
# This script pings a list of hostnames using both IPv4 and IPv6 protocols.
# It uses the 'dig' command to resolve the hostnames and then pings each IP
# address found. The script can run once or loop indefinitely with a sleep
# interval between iterations.
#
# This script is based on the original work by Steve Kemp.
# Original work Copyright (c) 2014 by Steve Kemp.
#
# The code in the original repository may be modified and distributed under your choice of:
#   * The Perl Artistic License (http://dev.perl.org/licenses/artistic.html) or
#   * The GNU General Public License, version 2 or later (http://www.gnu.org/licenses/gpl2.txt).
#
# Modifications and enhancements by Ismo Vuorinen on 2025.
#
# Usage:
# x-multi-ping [--loop|--forever] [--sleep=N] hostname1 hostname2 ...
#
# Options:
#   --help             Display this help message.
#   --loop, --forever  Loop indefinitely.
#   --sleep=N          Sleep N seconds between iterations (default: 1).
#
# Examples:
#   x-multi-ping example.com
#   x-multi-ping --loop --sleep=5 example.com
#   x-multi-ping --forever example.com example.org
#
# Dependencies:
#   - dig (DNS lookup utility)
#   - ping (ICMP ping utility)
#   - ping6 (IPv6 ping utility) or ping -6 (alternative)
#

# Defaults
LOOP=0
SLEEP=1
TIMEOUT=5

# Display usage information and options
usage()
{
  echo "Usage: $0 [--loop|--forever] [--sleep=N] hostname1 hostname2 ..."
  echo "Options:"
  echo "  --help           Display this help message."
  echo "  --loop, --forever  Loop indefinitely."
  echo "  --sleep=N        Sleep N seconds between iterations (default: 1)."
}

# Parse command-line options
while [[ $# -gt 0 ]]; do
  case "$1" in
    --help)
      usage
      exit 0
      ;;
    --loop | --forever)
      LOOP=1
      shift
      ;;
    --sleep=*)
      SLEEP="${1#*=}"
      shift
      ;;
    --sleep)
      if [[ -n "$2" ]]; then
        SLEEP="$2"
        shift 2
      else
        echo "Error: --sleep requires a numeric value."
        exit 1
      fi
      ;;
    --*)
      echo "Unknown option: $1"
      usage
      exit 1
      ;;
    *)
      break
      ;;
  esac
done

# Validate --sleep (both --sleep=N and --sleep N land in SLEEP)
if ! [[ "$SLEEP" =~ ^[0-9]+$ ]]; then
  echo "Error: --sleep requires a numeric value."
  exit 1
fi

# Check for required hostnames
if [[ $# -lt 1 ]]; then
  usage
  exit 1
fi

# Dependency check for dig and ping
if ! command -v dig > /dev/null 2>&1; then
  echo "The required 'dig' command is missing. Aborting."
  exit 1
fi

if ! command -v ping > /dev/null 2>&1; then
  echo "The required 'ping' command is missing. Aborting."
  exit 1
fi

# Determine how to invoke IPv6 ping
if command -v ping6 > /dev/null 2>&1; then
  PING6="ping6"
elif ping -6 -c1 ::1 > /dev/null 2>&1; then
  PING6="ping -6"
else
  echo "The required IPv6 ping command (ping6 or ping -6) is missing. Aborting."
  exit 1
fi

# ping flag dialects, computed once: macOS -t is the overall timeout in
# seconds; Linux uses -w (deadline) and -W (per-reply wait). macOS ping6
# has no deadline flag at all, so IPv6 pings there rely on -c1 alone.
if [[ "$(uname -s)" == "Darwin" ]]; then
  PING4_OPTS=(-c1 -t "$TIMEOUT")
  PING6_OPTS=(-c1)
else
  PING4_OPTS=(-c1 -w "$TIMEOUT" -W "$TIMEOUT")
  PING6_OPTS=(-c1 -w "$TIMEOUT" -W "$TIMEOUT")
fi

# Function to remove any URI scheme and port from the hostname.
strip_hostname()
{
  local host="$1"
  # Remove leading scheme (e.g., http://) if present.
  if [[ "$host" =~ ^[a-z]+://([^/]+)/? ]]; then
    host="${BASH_REMATCH[1]}"
  fi
  # Remove a port if specified (e.g., example.com:80).
  if [[ "$host" =~ ^([^:]+):[0-9]+$ ]]; then
    host="${BASH_REMATCH[1]}"
  fi
  echo "$host"
}

# Function to ping a given (already stripped) host based on DNS lookups.
pingHost()
{
  local host="$1"
  local type ip ips ping_cmd
  local -a opts

  for type in A AAAA; do
    # Binary and flags depend only on the record type.
    if [[ "$type" == "A" ]]; then
      ping_cmd="ping"
      opts=("${PING4_OPTS[@]}")
    else
      ping_cmd="$PING6"
      opts=("${PING6_OPTS[@]}")
    fi

    # Look up the DNS records for the host.
    ips=$(dig +short "$host" "$type")
    if [[ -z "$ips" ]]; then
      echo "WARNING: Failed to resolve $host [$type]"
      continue
    fi

    # Ping each resolved address (not the hostname, so every line
    # reports the address it actually probed).
    while IFS= read -r ip; do
      # shellcheck disable=SC2086  # PING6 may be "ping -6"
      if $ping_cmd "${opts[@]}" "$ip" > /dev/null 2>&1; then
        echo "Host $host - $ip - alive"
      else
        echo "Host $host - $ip - FAILED"
      fi
    done <<< "$ips"
  done
}

# Strip URI schemes/ports once up front; --loop reuses the cleaned list.
HOSTS=()
for host in "$@"; do
  HOSTS+=("$(strip_hostname "$host")")
done

# Main loop: run once or forever based on the options.
if [[ $LOOP -eq 1 ]]; then
  while true; do
    for host in "${HOSTS[@]}"; do
      pingHost "$host"
    done
    sleep "$SLEEP"
  done
else
  for host in "${HOSTS[@]}"; do
    pingHost "$host"
  done
fi
