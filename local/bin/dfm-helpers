#!/usr/bin/env bash
#USAGE cmd "helpers" help="Display system information and generate documentation" {
#USAGE   cmd "aliases" help="Show live shell aliases" {
#USAGE     arg "<shell>" help="Shell to show aliases for (bash, zsh, fish)"
#USAGE   }
#USAGE   cmd "colors" help="Show terminal color palette"
#USAGE   cmd "env" help="Show environment variables"
#USAGE   cmd "functions" help="Show shell functions"
#USAGE   cmd "path" help="Show PATH entries"
#USAGE   cmd "docs-aliases" help="Generate docs/aliases.md"
#USAGE   cmd "docs-nvim" help="Generate nvim keybindings documentation"
#USAGE   cmd "docs-tmux" help="Generate tmux keybindings documentation"
#USAGE   cmd "docs-wezterm" help="Generate wezterm keybindings documentation"
#USAGE   cmd "docs-all" help="Generate all documentation"
#USAGE }
#
# @description Display system information and generate documentation (dfm helpers)
# dfm helpers — display system information and generate documentation.
#
# vim: ft=bash ts=2 sw=2 et
# shellcheck source-path=$HOME/.dotfiles/local/bin

_dfm_dir=$(
  unset CDPATH
  cd -- "$(dirname -- "$0")" && pwd
)
# shellcheck source=local/bin/dfm-lib
if ! source "$_dfm_dir/dfm-lib"; then
  echo "${0##*/}: cannot load dfm-lib (broken install?)" >&2
  exit 1
fi
dfm_bootstrap_for "$@"

# Handle helper utility commands
dfm_helpers()
{
  USAGE_PREFIX="$SCRIPT helpers <command>"
  MENU=(
    "aliases:<shell> (bash, zsh, fish) Show live shell aliases"
    "colors:Show colors"
    "env:Show environment variables"
    "functions:Show functions"
    'path:Show $PATH dir by dir'
    "docs-aliases:Generate docs/aliases.md"
    "docs-nvim:Generate nvim keybindings documentation"
    "docs-tmux:Generate tmux keybindings documentation"
    "docs-wezterm:Generate wezterm keybindings documentation"
    "docs-all:Generate all documentation"
  )

  CMD="${1:-}"
  [[ $# -gt 0 ]] && shift
  SECTION="${1:-}"
  [[ $# -gt 0 ]] && shift

  case "$CMD" in
    path)
      # Split on ':' only, so PATH entries containing spaces stay intact.
      printf '%s\n' "$PATH" | tr ':' '\n'
      ;;

    aliases)
      case "$SECTION" in
        "zsh")
          zsh -ixc : 2>&1 | grep -E '> alias' | sed "s|$HOME|~|" | grep -v "(eval)"
          ;;
        "bash")
          bash -ixc : 2>&1 | grep -E '> alias' | sed "s|$HOME|~|" | grep -v "(eval)"
          ;;
        "fish")
          fish -ic "alias" | sed "s|$HOME|~|"
          ;;
        *)
          echo "$SCRIPT helpers aliases <shell> (bash, zsh, fish)"
          ;;
      esac
      ;;

    "colors")
      max=255
      start=0

      while [ "$start" -le "$max" ]; do
        for i in $(seq "$start" $((start + 9))); do
          if [ "$i" -le "$max" ]; then
            # Outputs colored number
            # printf " \e[38;5;%sm%4s\e[0m" "$i" "$i"

            # Outputs colored block with number inside
            # printf " \e[48;5;%sm\e[38;5;15m%5s \e[0m" "$i" "$i"

            # Outputs colored block and color number
            # printf " \e[48;5;%sm   \e[0m %3d" "$i" "$i"

            # Outputs color number and colored block
            printf "%3d \e[48;5;%sm   \e[0m " "$i" "$i"
          fi
        done
        printf "\n"
        start=$((start + 10))
      done
      ;;

    "env") env | sort ;;
    "functions") declare -F ;;

    "docs-aliases") bash "$DOTFILES/scripts/update-readme-aliases.sh" ;;
    "docs-nvim") bash "$DOTFILES/scripts/create-nvim-keymaps.sh" ;;
    "docs-tmux") bash "$DOTFILES/local/bin/x-dfm-docs-tmux-keybindings" ;;
    "docs-wezterm") bash "$DOTFILES/scripts/create-wezterm-keymaps.sh" ;;
    "docs-all")
      local rc=0
      dfm_helpers docs-aliases || rc=1
      dfm_helpers docs-tmux || rc=1
      dfm_helpers docs-nvim || rc=1
      dfm_helpers docs-wezterm || rc=1
      return "$rc"
      ;;

    *) menu_builder "$USAGE_PREFIX" "${MENU[@]}" ;;
  esac
}

dfm_helpers "$@"
