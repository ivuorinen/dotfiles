#!/usr/bin/env bash
#USAGE cmd "brew" help="Homebrew package management" {
#USAGE   cmd "install" help="Install packages from Brewfile"
#USAGE   cmd "update" help="Update Homebrew and packages"
#USAGE   cmd "updatebundle" help="Deprecated: formulae now managed by mise"
#USAGE   cmd "autoupdate" help="Setup Homebrew auto-update"
#USAGE   cmd "leaves" help="Deprecated: use mise bootstrap packages status"
#USAGE   cmd "clean" help="Deprecated: would remove mise-managed formulae"
#USAGE   cmd "untracked" help="Deprecated: formulae now tracked by mise"
#USAGE }
#
# @description Homebrew package management (dfm brew)
# dfm brew — Homebrew package management.
#
# vim: ft=bash ts=2 sw=2 et
# shellcheck source-path=$HOME/.dotfiles/local/bin

_dfm_dir=$(
  unset CDPATH
  cd -- "$(dirname -- "$0")" && pwd
)
# shellcheck source=local/bin/dfm-lib
if ! source "$_dfm_dir/dfm-lib"; then
  echo "${0##*/}: cannot load dfm-lib (broken install?)" >&2
  exit 1
fi
dfm_bootstrap_for "$@"

# Report a brew subcommand as deprecated by the mise brew-bootstrap migration.
# Plain homebrew/core CLI formulae now live in mise's [bootstrap.packages]
# (config/mise/config.toml); commands that dump or prune the Brewfile would
# fight that split, so they no-op with a pointer to the mise equivalent.
# $1 = subcommand name, $2 = guidance line. Always returns 0.
brew_deprecated()
{
  msgr warn "dfm brew $1 is deprecated after the mise brew-bootstrap migration."
  msgr nested "$2"
  return 0
}

# Handle Homebrew section commands
dfm_brew()
{
  USAGE_PREFIX="$SCRIPT brew <command>"

  MENU=(
    "install:Installs items defined in Brewfile"
    "update:Updates and upgrades brew packages"
    "updatebundle:Deprecated (formulae now managed by mise)"
    "autoupdate:Setups brew auto-update and runs it immediately"
    "leaves:Deprecated (use mise bootstrap packages status)"
    "clean:Deprecated (would remove mise-managed formulae)"
    "untracked:Deprecated (formulae now tracked by mise)"
  )

  # Homebrew may be absent (a minimal Linux box). Without it there is
  # nothing to list or run, so emit just this notice and stop — this gates
  # the menu too. `dfm` omits the whole section on such systems (see
  # dfm_section_requires in the dispatcher); a direct `dfm brew` lands here
  # and shows only this. command -v (not x-have) keeps the check working
  # under the cheap menu-path bootstrap, which does not source shared.sh.
  if ! command -v brew > /dev/null 2>&1; then
    msgr warn "brew not available on this system"
    return 0
  fi

  case "$1" in
    install)
      brew bundle install --file="$BREWFILE" --force --quiet && msgr yay "Done!"
      ;;

    update)
      if brew update && brew outdated && brew upgrade && brew cleanup; then
        msgr yay "Done!"
      else
        msgr err "brew update failed"
      fi
      ;;

    updatebundle)
      # `brew bundle dump` would re-add every migrated homebrew/core formula to
      # the Brewfile, undoing the migration. The Brewfile is curated by hand now.
      brew_deprecated updatebundle \
        "The Brewfile is curated; formulae live in mise [bootstrap.packages]. Use 'mise bootstrap packages import --manager brew' to snapshot into mise instead."
      ;;

    leaves)
      # Migrated formulae still appear as brew leaves, so this now mixes
      # mise-managed and native-brew formulae. mise tracks its own set.
      brew_deprecated leaves \
        "Run 'mise bootstrap packages status' for mise-managed formulae, or 'brew leaves --installed-on-request' directly for the native-brew stack (casks/php/media)."
      ;;

    untracked)
      # The 49 migrated formulae are installed but intentionally absent from the
      # Brewfile, so the old diff would report every one of them as "untracked".
      # They are tracked by mise now, which makes this listing meaningless.
      brew_deprecated untracked \
        "Migrated formulae are tracked in mise [bootstrap.packages]; check 'mise bootstrap packages status'. Casks live in the Brewfile."
      ;;

    autoupdate)
      brew autoupdate delete
      brew autoupdate start 43200 --upgrade --cleanup --immediate
      ;;

    clean)
      # `brew bundle cleanup` uninstalls anything not in the Brewfile — which
      # now includes the mise-managed formulae. Neutralised to prevent removing
      # them. `dfm brew update` still runs `brew cleanup` for real brew cruft.
      brew_deprecated clean \
        "It would uninstall mise-managed formulae. mise owns its bootstrap packages; use 'dfm brew update' (runs brew cleanup) for cask/php cruft."
      ;;

    *) menu_builder "$USAGE_PREFIX" "${MENU[@]}" ;;
  esac
}

dfm_brew "$@"
