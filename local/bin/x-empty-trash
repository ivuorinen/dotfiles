#!/usr/bin/env bash
# @description Empty the Trash on all mounted volumes and clear old system logs (macOS)
#USAGE about "Empty Trash on all volumes and clear old system logs (macOS)"

set -euo pipefail

if [ "$(uname -s)" != Darwin ]; then
  echo "x-empty-trash is macOS-only" >&2
  exit 1
fi

# Volume Trashes and ASL logs may not exist; treat their absence as success.
sudo rm -rfv /Volumes/*/.Trashes 2> /dev/null || true
sudo rm -rfv "$HOME/.Trash"
sudo rm -rfv /private/var/log/asl/*.asl 2> /dev/null || true
