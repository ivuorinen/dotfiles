#!/usr/bin/env bash
#USAGE cmd "install" help="Install tools, packages, and configurations" {
#USAGE   cmd "all" help="Install everything in the correct order"
#USAGE   cmd "apt-packages" help="Install apt packages (Debian/Ubuntu)"
#USAGE   cmd "cheat-databases" help="Install cheat external cheatsheet databases"
#USAGE   cmd "composer" help="Install PHP Package Manager Composer"
#USAGE   cmd "dnf-packages" help="Install dnf packages (Fedora/RHEL)"
#USAGE   cmd "fonts" help="Install programming fonts"
#USAGE   cmd "gh" help="Install GitHub CLI Extensions"
#USAGE   cmd "imagick" help="Install ImageMagick CLI"
#USAGE   cmd "macos" help="Setup nice macOS defaults"
#USAGE   cmd "mise" help="Install tools via mise (runtimes + CLI tools)"
#USAGE   cmd "mise-cleanup" help="Remove old version manager installations" {
#USAGE     flag "--dry-run" help="Show what would be removed without removing"
#USAGE   }
#USAGE   cmd "ntfy" help="Install ntfy notification tool"
#USAGE   cmd "python-libs" help="Install Python libraries (libtmux, pynvim)"
#USAGE   cmd "shellspec" help="Install shellspec testing framework"
#USAGE   cmd "xcode-cli-tools" help="Install Xcode CLI tools (macOS)"
#USAGE   cmd "z" help="Install z directory jumper"
#USAGE }
#
# @description Install tools, packages, and configurations (dfm install)
# dfm install — install tools, packages, and configurations.
#
# vim: ft=bash ts=2 sw=2 et
# shellcheck source-path=$HOME/.dotfiles/local/bin

_dfm_dir=$(
  unset CDPATH
  cd -- "$(dirname -- "$0")" && pwd
)
# shellcheck source=local/bin/dfm-lib
if ! source "$_dfm_dir/dfm-lib"; then
  echo "${0##*/}: cannot load dfm-lib (broken install?)" >&2
  exit 1
fi
dfm_bootstrap_for "$@"

# Collected outcomes for the `install all` closing summary.
_install_failures=()
_install_skips=()

# Run one install step, logging (never aborting) on failure so `install all`
# always reaches the end. A partial install is surfaced in the summary rather
# than dying at the first broken step.
run_step()
{
  local label="$1"
  shift
  local rc=0
  "$@" || rc=$?
  if [[ "$rc" -ne 0 ]]; then
    msgr err "Step failed (continuing): $label [exit $rc]"
    _install_failures+=("$label")
  fi
  return 0
}

# Guard a step on a tool it needs. Returns non-zero so the caller skips the
# step, and records the skip — e.g. once mise itself fails, every step that
# relies on a mise-installed tool skips cleanly instead of erroring.
require_bin()
{
  local label="$1" bin="$2"
  command -v "$bin" > /dev/null 2>&1 && return 0
  msgr warn "Skipping $label: required tool '$bin' not found"
  _install_skips+=("$label (needs $bin)")
  return 1
}

# Handle install section commands
dfm_install()
{
  USAGE_PREFIX="$SCRIPT install <command>"

  MENU=(
    "all:Installs everything in the correct order"
    "apt-packages:Install apt packages (Debian/Ubuntu)"
    "cheat-databases:Install cheat external cheatsheet databases"
    "composer:Install composer"
    "dnf-packages:Install dnf packages (Fedora/RHEL)"
    "fonts:Install programming fonts"
    "gh:Install GitHub CLI Extensions"
    "imagick:Install ImageMagick CLI"
    "macos:Setup nice macOS defaults"
    "mise:Install tools via mise (runtimes + CLI tools)"
    "mise-cleanup:Remove old version manager installations (--dry-run supported)"
    "ntfy:Install ntfy notification tool"
    "python-libs:Install Python libraries (libtmux, pynvim)"
    "shellspec:Install shellspec testing framework"
    "xcode-cli-tools:Install Xcode CLI tools (macOS)"
    "z:Install z"
  )

  case "$1" in
    all)
      msgr msg "Starting to install all and reloading configurations..."
      _install_failures=()
      _install_skips=()

      # Tier 0: Platform foundations (OS packages, build tools)
      [[ "$(uname)" == "Darwin" ]] && run_step "macos defaults" dfm_install macos
      [[ "$(uname)" == "Darwin" ]] && run_step "xcode cli tools" dfm_install xcode-cli-tools
      command -v apt &> /dev/null && run_step "apt packages" dfm_install apt-packages
      command -v dnf &> /dev/null && run_step "dnf packages" dfm_install dnf-packages

      # Tier 1: Package managers & fonts
      run_step "homebrew" "$DFM" brew install
      run_step "fonts" dfm_install fonts

      # Tier 2: Runtimes and CLI tools via mise, then remaining installers.
      # mise is the lynchpin: a failed *tool* (e.g. a host-unsupported dotnet
      # tool) no longer aborts the run — the mise step stays usable and the
      # steps below simply skip themselves if mise is genuinely absent.
      run_step "mise" dfm_install mise
      run_step "composer" dfm_install composer
      require_bin "python libraries" mise && run_step "python libraries" dfm_install python-libs

      # Tier 3: Tool-dependent installers
      run_step "cheat databases" dfm_install cheat-databases
      require_bin "gh extensions" gh && run_step "gh extensions" dfm_install gh
      require_bin "ntfy" mise && run_step "ntfy" dfm_install ntfy

      # Tier 4: Independent utilities
      run_step "shellspec" dfm_install shellspec
      run_step "z" dfm_install z

      # Tier 5: Generate completions, docs, and manpages from usage specs
      msgr run "Generating completions and docs from usage specs..."
      if bash "$DOTFILES/scripts/install-completions.sh"; then
        msgr run_done "Completions and docs generated!"
      else
        msgr warn "Some completions/docs failed to generate (non-fatal)"
      fi

      msgr msg "Reloading configurations again..."
      # shellcheck disable=SC1091
      source "$DOTFILES/config/shared.sh"

      # Closing summary: surface skips and failures so a partial install is
      # visible instead of silently incomplete.
      if [[ ${#_install_skips[@]} -gt 0 ]]; then
        msgr warn "Skipped ${#_install_skips[@]} step(s):"
        for _s in "${_install_skips[@]}"; do msgr nested "$_s"; done
      fi
      if [[ ${#_install_failures[@]} -gt 0 ]]; then
        msgr err "Completed with ${#_install_failures[@]} failed step(s):"
        for _f in "${_install_failures[@]}"; do msgr nested "$_f"; done
      else
        msgr yay "All done!"
      fi
      ;;

    cheat-databases)
      msgr run "Installing cheat databases..."
      for database in "$DOTFILES"/scripts/install-cheat-*.sh; do
        bash "$database" \
          && msgr run_done "Cheat: $database run"
      done
      ;;

    composer)
      msgr run "Installing composer..."
      bash "$DOTFILES/scripts/install-composer.sh" \
        && msgr run_done "composer installed!"
      ;;

    fonts)
      msgr run "Installing fonts..."
      bash "$DOTFILES/scripts/install-fonts.sh" \
        && msgr yay "Installed fonts!"
      ;;

    gh)
      msgr run "Installing GitHub CLI Extensions..."
      bash "$DOTFILES/scripts/install-gh-extensions.sh" \
        && msgr yay "github cli extensions installed!"
      ;;

    imagick)
      msgr run "Downloading and installing ImageMagick CLI..."
      curl -L https://imagemagick.org/archive/binaries/magick > "$XDG_BIN_HOME/magick" \
        && chmod +x "$XDG_BIN_HOME/magick" \
        && msgr yay "imagick downloaded and installed!"
      ;;

    macos)
      msgr run "Setting up macOS defaults..."
      bash "$DOTFILES/scripts/install-macos-defaults.sh" \
        && msgr yay "macOS defaults set!"
      ;;

    mise)
      msgr run "Installing tools via mise..."
      if ! command -v mise &> /dev/null; then
        msgr nested "Installing mise..."
        curl -fsSL https://mise.run | sh || {
          # No mise binary means nothing downstream can run — the one case
          # where the mise step is genuinely fatal (caller records it and
          # skips the mise-dependent steps).
          msgr err "Failed to install mise"
          return 1
        }
        export PATH="${XDG_BIN_HOME:-$HOME/.local/bin}:$PATH"
      fi
      if [[ -z "${GITHUB_TOKEN:-}" ]]; then
        msgr warn "GITHUB_TOKEN is not set — mise queries GitHub API for each github: tool"
        msgr nested "Unauthenticated requests are rate-limited to 60/hr; installs may fail mid-run"
        if [[ -t 0 ]]; then
          read -rp "Create GITHUB_TOKEN secrets now? [y/N] " _answer
          if [[ "${_answer:-N}" =~ ^[Yy]$ ]]; then
            "$DFM" secrets github
            # shellcheck disable=SC1090
            [[ -f "$DOTFILES/config/secrets.d/github.sh" ]] \
              && source "$DOTFILES/config/secrets.d/github.sh"
          fi
          unset _answer
        else
          msgr nested "Non-interactive shell; skipping token prompt"
        fi
      fi
      # A single host-unsupported tool (e.g. a dotnet tool that will not build
      # on this box) makes `mise install` exit non-zero even though every other
      # tool installed. Do not abort on that — warn and still reshim so the
      # tools that DID install get their shims.
      mise install --yes \
        || msgr warn "Some mise tools failed to install (host-unsupported?); continuing"
      mise reshim \
        || msgr warn "mise reshim failed (non-fatal)"
      # Apply [bootstrap.packages] — Homebrew formulae mise installs into the
      # canonical prefix (/opt/homebrew) without the brew CLI. macOS-only, since
      # these mirror the macOS Brewfile; scoped to the brew manager and kept
      # non-fatal because the feature is experimental.
      if [[ "$(uname -s)" == "Darwin" ]]; then
        msgr nested "Applying mise bootstrap brew packages..."
        mise bootstrap packages apply --manager brew --yes \
          || msgr warn "mise bootstrap packages apply failed (non-fatal)"
      fi
      msgr yay "mise tools installed!"
      ;;

    mise-cleanup)
      msgr run "Cleaning up old version manager installations..."
      bash "$DOTFILES/scripts/cleanup-old-version-managers.sh" "${@:2}"
      ;;

    apt-packages)
      # System packages need sudo; auto-skip on hosts where this user has no
      # sudo rights (e.g. shared servers) rather than failing mid-install.
      if "$DOTFILES/local/bin/is-sudoer"; then
        msgr run "Installing apt packages..."
        bash "$DOTFILES/scripts/install-apt-packages.sh" \
          && msgr yay "apt packages installed!"
      else
        msgr warn "Skipping apt packages: $(id -un) has no sudo privileges"
      fi
      ;;

    dnf-packages)
      if "$DOTFILES/local/bin/is-sudoer"; then
        msgr run "Installing dnf packages..."
        bash "$DOTFILES/scripts/install-dnf-packages.sh" \
          && msgr yay "dnf packages installed!"
      else
        msgr warn "Skipping dnf packages: $(id -un) has no sudo privileges"
      fi
      ;;

    ntfy)
      msgr run "Installing ntfy via mise..."
      mise install "github:binwiederhier/ntfy" \
        && msgr yay "ntfy installed!"
      ;;

    python-libs)
      msgr run "Installing Python libraries..."
      bash "$DOTFILES/scripts/install-python-packages.sh" \
        && msgr yay "Python libraries installed!"
      ;;

    xcode-cli-tools)
      msgr run "Installing Xcode CLI tools..."
      bash "$DOTFILES/scripts/install-xcode-cli-tools.sh" \
        && msgr yay "Xcode CLI tools installed!"
      ;;

    shellspec)
      msgr run "Installing shellspec..."
      bash "$DOTFILES/scripts/install-shellspec.sh" \
        && msgr yay "shellspec has been installed!"
      ;;

    z)
      msgr run "Installing z..."
      bash "$DOTFILES/scripts/install-z.sh" \
        && msgr yay "z has been installed!"
      ;;

    *) menu_builder "$USAGE_PREFIX" "${MENU[@]}" ;;
  esac
}

dfm_install "$@"
