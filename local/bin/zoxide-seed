#!/usr/bin/env bash
# Bulk-seed the zoxide database from common project and config directories.
# Passes all found paths to a single zoxide add invocation — avoids
# spawning one process per path.

set -uo pipefail

command -v fd > /dev/null 2>&1 || exit 0
command -v zoxide > /dev/null 2>&1 || exit 0

mapfile -t paths < <(
  fd --type d --max-depth 3 \
    --exclude .git \
    --exclude node_modules \
    --exclude .cache \
    --exclude __pycache__ \
    --exclude target \
    --exclude dist \
    --exclude .yarn \
    . "${HOME}/Code" "${HOME}/.config" "${HOME}/.dotfiles" 2> /dev/null
  fd --type d --max-depth 1 . "${HOME}" 2> /dev/null
)

[[ ${#paths[@]} -gt 0 ]] && zoxide add "${paths[@]}"
