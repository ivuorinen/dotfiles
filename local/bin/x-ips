#!/usr/bin/env bash
#USAGE about "Show local IPv4/IPv6 addresses"
#
# List this machine's local IPv4/IPv6 addresses via ifconfig.
# Also reachable as `x ips`.

set -euo pipefail

if ! command -v ifconfig &> /dev/null; then
  echo "Error: ifconfig is required" >&2
  exit 1
fi

ifconfig -a \
  | grep -o 'inet6\? \(\([0-9]\+\.[0-9]\+\.[0-9]\+\.[0-9]\+\)\|[a-fA-F0-9:]\+\)' \
  | sed -e 's/inet6* //' \
  | sort
