!.gitkeep
*-secret
*.bak
*.log
*.socket
*.swp
*.old
*.sql
*cache

# Stray exported GPG public keys. gopass keeps the authoritative copy in
# its store's .public-keys/ (synced via the store's own remote) and the
# keyring holds the importable copy, so loose exports never belong here.
*.pub.key
.env
.idea
.nfs*
.scannerwork
.vscode
.yarn/
!config/git/local.d/.gitkeep
!config/nvim/spell/.gitkeep
!config/zed/settings.json
!ssh/local.d/.gitkeep
**/exports-secret.fish
**/exports.secret.fish
*.tmp.*
Brewfile.lock.json
antidote_plugins.zsh
config/alacritty/theme-active.toml
config/cheat/cheatsheets/pure-bash-bible/*
config/cheat/cheatsheets/tldr/*
config/fish/completions/asdf.fish
config/fish/completions/kubectl.fish
config/fish/completions/orbctl.fish
config/fish/fish_variables
config/fish/fish_variables.*
config/fish/secrets.d/*
!config/fish/secrets.d/*.example
!config/fish/secrets.d/README.md
config/secrets.d/*
!config/secrets.d/*.example
!config/secrets.d/README.md
config/gh/hosts.yml
config/git/credentials
config/git/local.d/*
config/gnupg/S.*
config/gnupg/private-keys-v1.d
config/gnupg/s
config/iterm2/AppSupport
config/karabiner/automatic_backups
config/npm/npmrc
config/nvim/lazy-lock.json
config/nvim/spell/*
config/op/plugins/gh.json
config/op/plugins/used_items/gh.json
config/vim/.netrwhist
config/vim/extra/*
config/vim/fzf
config/vim/plugged/*
config/zed/*
config/zed/settings.json
config/zsh/.zcompdump
dependency-check-report.html
iTermServer-*
lazy-lock.json
local/bin/asdf/plugins/*
local/bin/yabai
local/man/yabai.1
local/share/fonts/*
lock
node_modules
__pycache__
ssh/local.d/*
config/fish/fish_variables*
cr.md

# Generated by usage-cli (regenerated via scripts/install-completions.sh)
config/bash/completions.d/
config/fish/completions/*.fish
!config/fish/completions/aqua.fish
!config/fish/completions/bob.fish
!config/fish/completions/docker.fish
!config/fish/completions/fisher.fish
!config/fish/completions/git-profile.fish
!config/fish/completions/golangci-lint.fish
!config/fish/completions/grype.fish
!config/fish/completions/mise.fish
!config/fish/completions/phpenv.fish
!config/fish/completions/pinact.fish
!config/fish/completions/sesh.fish
!config/fish/completions/wezterm.fish
config/zsh/completions.d/
local/md/
local/man/man1/*.1
!local/man/man1/fzf.1
!local/man/man1/fzf-tmux.1

# Allow .claude directory (overrides global **/.claude/* ignore)
!.claude/
!.claude/**
.claude/**/*.log
.claude/settings.local.json

# Allow docs/superpowers/ (overrides global **/docs/superpowers/* ignore
# from the host gitignore override). Plans in this dir are part of the PR
# record and should be trackable without `git add -f`.
!docs/superpowers/
!docs/superpowers/**
!docs/audit/**

# Allow per-directory CLAUDE.md files in this repo (overrides the global
# CLAUDE.md ignore from the host gitignore override). They document
# subsystem conventions and should ship with the code they describe.
!CLAUDE.md
!**/CLAUDE.md
